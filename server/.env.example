# Database (SQLite - optional custom path, default: server/db/database.sqlite)
# DB_PATH=./db/database.sqlite

# LLM Providers
LM_STUDIO_URL=http://192.168.1.20:12345/v1
GLM_API_KEY=your-glm-api-key-here
GLM_API_URL=https://open.bigmodel.cn/api/paas/v4
OPENROUTER_API_KEY=your-openrouter-api-key-here
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_CLOUD_URL=https://your-ollama-cloud.com/v1
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_API_URL=https://api.minimax.io/v1

# Server
PORT=3001
HOST=localhost

# Security (recommended for network exposure)
# Set to true when exposing server on 0.0.0.0
API_KEY_REQUIRED=false
API_KEY=your-secret-api-key-here
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development
